rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: sync_data
    // Document ID: {code} (string)
    // Fields:
    //   - code: string (required) - Unique synchronization code
    //   - data: string (required) - JSON string of the synchronized data
    //   - updated_at: timestamp (required) - Last update timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "mertmetetekin@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidSyncData(data) {
      return hasRequiredFields(['code', 'data', 'updated_at']) &&
             hasOnlyAllowedFields(['code', 'data', 'updated_at']) &&
             data.code is string && data.code.size() > 0 && data.code.size() < 100 &&
             data.data is string && data.data.size() < 1048576; // Max 1MB
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /sync_data/{code} {
      // Allowing public access to sync data via the unique code.
      // This enables sharing without requiring a Google login on every device.
      allow read: if true;
      allow create: if isValidSyncData(request.resource.data);
      allow update: if isValidSyncData(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
